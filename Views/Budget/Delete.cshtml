@model ExpenseTracker.Models.Domain.Budget

@{
    ViewData["Title"] = "Delete Budget";
    var label = Model.Category?.ToString() ?? "Overall";
}

<h1><i class="bi bi-trash me-2"></i>Delete Budget</h1>
<h3 class="text-danger">Are you sure you want to delete this budget?</h3>
<hr />
<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary">@label</span></dd>
                    <dt class="col-sm-4">Amount</dt>
                    <dd class="col-sm-8">@Model.Amount.ToString("C")</dd>
                    <dt class="col-sm-4">Month</dt>
                    <dd class="col-sm-8">@Model.YearMonth</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
<div class="mt-3">
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        <a asp-action="Index" asp-route-yearMonth="@Model.YearMonth" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
