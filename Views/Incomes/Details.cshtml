@model ExpenseTracker.Models.Domain.Income

@{
    ViewData["Title"] = "Income Details";
}

<h1><i class="bi bi-eye me-2"></i>Income Details</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Amount</dt>
                    <dd class="col-sm-8">@Model.Amount.ToString("C")</dd>
                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8">@Model.Date.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-4">Source</dt>
                    <dd class="col-sm-8">@Model.Source</dd>
                    <dt class="col-sm-4">Month</dt>
                    <dd class="col-sm-8">@Model.YearMonth</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
</div>
