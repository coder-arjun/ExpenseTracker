@model ExpenseTracker.Models.PaginatedList<ExpenseTracker.Models.Domain.Income>

@{
    ViewData["Title"] = "Incomes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Incomes</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add Income
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Source</th>
                    <th>Month</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Date.ToString("yyyy-MM-dd")</td>
                        <td>@item.Amount.ToString("C")</td>
                        <td>@item.Source</td>
                        <td>@item.YearMonth</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@{
    ViewData["PageIndex"] = Model.PageIndex;
    ViewData["TotalPages"] = Model.TotalPages;
    ViewData["HasPreviousPage"] = Model.HasPreviousPage;
    ViewData["HasNextPage"] = Model.HasNextPage;
}
<partial name="_PaginationPartial" />
